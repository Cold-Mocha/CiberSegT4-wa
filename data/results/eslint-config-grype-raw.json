 known as mXSS (mutation XSS). More specifically, this can occur when injecting malicious content into an attribute within a `noscript` tag. This issue has been addressed in release version 4.2.19. Users are advised to upgrade. There are no known workarounds for this vulnerability.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:C/C:L/I:L/A:N","metrics":{"baseScore":6.1,"exploitabilityScore":2.9,"impactScore":2.8},"vendorMetadata":{}},{"source":"security-advisories@github.com","type":"Secondary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:U/C:L/I:L/A:N","metrics":{"baseScore":5.4,"exploitabilityScore":2.9,"impactScore":2.6},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2024-45047","epss":0.00383,"percentile":0.59661,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2024-45047","cwe":"CWE-79","source":"security-advisories@github.com","type":"Secondary"},{"cve":"CVE-2024-45047","cwe":"CWE-79","source":"nvd@nist.gov","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"svelte","version":"4.2.18"}},"found":{"vulnerabilityID":"GHSA-8266-84wp-wv5c","versionConstraint":"<4.2.19 (semantic)"},"fix":{"suggestedVersion":"4.2.19"}}],"artifact":{"id":"f961ef650edc323b","name":"svelte","version":"4.2.18","type":"npm","locations":[{"path":"/pnpm-lock.yaml","accessPath":"/pnpm-lock.yaml","annotations":{"evidence":"primary"}}],"language":"javascript","licenses":[],"cpes":["cpe:2.3:a:svelte:svelte:4.2.18:*:*:*:*:node.js:*:*"],"purl":"pkg:npm/svelte@4.2.18","upstreams":[]}},{"vulnerability":{"id":"GHSA-phwv-c562-gvmh","dataSource":"https://github.com/advisories/GHSA-phwv-c562-gvmh","namespace":"github:language:javascript","severity":"Medium","urls":["https://github.com/sveltejs/svelte/security/advisories/GHSA-phwv-c562-gvmh","https://nvd.nist.gov/vuln/detail/CVE-2026-27901","https://github.com/sveltejs/svelte/commit/0df5abcae223058ceb95491470372065fb87951d","https://github.com/sveltejs/svelte/releases/tag/svelte@5.53.5"],"description":"Svelte vulnerable to XSS during SSR with contenteditable `bind:innerText` and `bind:textContent`","cvss":[{"type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:H/AT:P/PR:N/UI:P/VC:L/VI:N/VA:N/SC:H/SI:H/SA:N","metrics":{"baseScore":5.3},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-27901","epss":0.00029,"percentile":0.08241,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2026-27901","cwe":"CWE-79","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["5.53.5"],"state":"fixed","available":[{"version":"5.53.5","date":"2026-02-27","kind":"first-observed"}]},"advisories":[],"risk":0.014935},"relatedVulnerabilities":[{"id":"CVE-2026-27901","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-27901","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/sveltejs/svelte/commit/0df5abcae223058ceb95491470372065fb87951d","https://github.com/sveltejs/svelte/releases/tag/svelte%405.53.5","https://github.com/sveltejs/svelte/security/advisories/GHSA-phwv-c562-gvmh"],"description":"Svelte performance oriented web framework. Prior to version 5.53.5, the contents of `bind:innerText` and `bind:textContent` on `contenteditable` elements were not properly escaped. This could enable HTML injection and Cross-Site Scripting (XSS) if rendering untrusted data as the binding's initial value on the server. Version 5.53.5 fixes the issue.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:N/UI:R/S:C/C:L/I:L/A:N","metrics":{"baseScore":6.1,"exploitabilityScore":2.9,"impactScore":2.8},"vendorMetadata":{}},{"source":"security-advisories@github.com","type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:H/AT:P/PR:N/UI:P/VC:L/VI:N/VA:N/SC:H/SI:H/SA:N/E:X/CR:X/IR:X/AR:X/MAV:X/MAC:X/MAT:X/MPR:X/MUI:X/MVC:X/MVI:X/MVA:X/MSC:X/MSI:X/MSA:X/S:X/AU:X/R:X/V:X/RE:X/U:X","metrics":{"baseScore":5.3},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-27901","epss":0.00029,"percentile":0.08241,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2026-27901","cwe":"CWE-79","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"svelte","version":"4.2.18"}},"found":{"vulnerabilityID":"GHSA-phwv-c562-gvmh","versionConstraint":"<=5.53.4 (semantic)"},"fix":{"suggestedVersion":"5.53.5"}}],"artifact":{"id":"f961ef650edc323b","name":"svelte","version":"4.2.18","type":"npm","locations":[{"path":"/pnpm-lock.yaml","accessPath":"/pnpm-lock.yaml","annotations":{"evidence":"primary"}}],"language":"javascript","licenses":[],"cpes":["cpe:2.3:a:svelte:svelte:4.2.18:*:*:*:*:node.js:*:*"],"purl":"pkg:npm/svelte@4.2.18","upstreams":[]}},{"vulnerability":{"id":"GHSA-crpf-4hrx-3jrp","dataSource":"https://github.com/advisories/GHSA-crpf-4hrx-3jrp","namespace":"github:language:javascript","severity":"Medium","urls":["https://github.com/sveltejs/svelte/security/advisories/GHSA-crpf-4hrx-3jrp","https://github.com/sveltejs/svelte/commit/73098bb26c6f06e7fd1b0746d817d2c5ee90755f","https://github.com/sveltejs/svelte/releases/tag/svelte@5.51.5","https://nvd.nist.gov/vuln/detail/CVE-2026-27125"],"description":"Svelte SSR attribute spreading includes inherited properties from prototype chain","cvss":[{"type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:H/AT:P/PR:L/UI:N/VC:L/VI:L/VA:N/SC:H/SI:H/SA:N","metrics":{"baseScore":5.3},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-27125","epss":0.00026,"percentile":0.0706,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2026-27125","cwe":"CWE-915","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["5.51.5"],"state":"fixed","available":[{"version":"5.51.5","date":"2026-03-04","kind":"first-observed"}]},"advisories":[],"risk":0.01339},"relatedVulnerabilities":[{"id":"CVE-2026-27125","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-27125","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/sveltejs/svelte/commit/73098bb26c6f06e7fd1b0746d817d2c5ee90755f","https://github.com/sveltejs/svelte/releases/tag/svelte@5.51.5","https://github.com/sveltejs/svelte/security/advisories/GHSA-crpf-4hrx-3jrp"],"description":"svelte performance oriented web framework. Prior to 5.51.5, in server-side rendering, attribute spreading on elements (e.g. <div {...attrs}>) enumerates inherited properties from the object's prototype chain rather than only own properties. In environments where Object.prototype has already been polluted — a precondition outside of Svelte's control — this can cause unexpected attributes to appear in SSR output or cause SSR to throw errors. Client-side rendering is not affected. This vulnerability is fixed in 5.51.5.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:H/PR:L/UI:N/S:U/C:H/I:H/A:N","metrics":{"baseScore":6.8,"exploitabilityScore":1.7,"impactScore":5.2},"vendorMetadata":{}},{"source":"security-advisories@github.com","type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:H/AT:P/PR:L/UI:N/VC:L/VI:L/VA:N/SC:H/SI:H/SA:N/E:X/CR:X/IR:X/AR:X/MAV:X/MAC:X/MAT:X/MPR:X/MUI:X/MVC:X/MVI:X/MVA:X/MSC:X/MSI:X/MSA:X/S:X/AU:X/R:X/V:X/RE:X/U:X","metrics":{"baseScore":5.3},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-27125","epss":0.00026,"percentile":0.0706,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2026-27125","cwe":"CWE-915","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"svelte","version":"4.2.18"}},"found":{"vulnerabilityID":"GHSA-crpf-4hrx-3jrp","versionConstraint":"<=5.51.4 (semantic)"},"fix":{"suggestedVersion":"5.51.5"}}],"artifact":{"id":"f961ef650edc323b","name":"svelte","version":"4.2.18","type":"npm","locations":[{"path":"/pnpm-lock.yaml","accessPath":"/pnpm-lock.yaml","annotations":{"evidence":"primary"}}],"language":"javascript","licenses":[],"cpes":["cpe:2.3:a:svelte:svelte:4.2.18:*:*:*:*:node.js:*:*"],"purl":"pkg:npm/svelte@4.2.18","upstreams":[]}},{"vulnerability":{"id":"GHSA-f7gr-6p89-r883","dataSource":"https://github.com/advisories/GHSA-f7gr-6p89-r883","namespace":"github:language:javascript","severity":"Medium","urls":["https://github.com/sveltejs/svelte/security/advisories/GHSA-f7gr-6p89-r883","https://nvd.nist.gov/vuln/detail/CVE-2026-27121"],"description":"Svelte affected by cross-site scripting via spread attributes in Svelte SSR","cvss":[{"type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:H/AT:P/PR:H/UI:N/VC:L/VI:N/VA:N/SC:H/SI:H/SA:N","metrics":{"baseScore":5.1},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-27121","epss":0.00011,"percentile":0.01267,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2026-27121","cwe":"CWE-79","source":"security-advisories@github.com","type":"Primary"}],"fix":{"versions":["5.51.5"],"state":"fixed","available":[{"version":"5.51.5","date":"2026-03-04","kind":"first-observed"}]},"advisories":[],"risk":0.005555},"relatedVulnerabilities":[{"id":"CVE-2026-27121","dataSource":"https://nvd.nist.gov/vuln/detail/CVE-2026-27121","namespace":"nvd:cpe","severity":"Medium","urls":["https://github.com/sveltejs/svelte/security/advisories/GHSA-f7gr-6p89-r883"],"description":"svelte performance oriented web framework. Versions of svelte prior to 5.51.5 are vulnerable to cross-site scripting (XSS) during server-side rendering. When using spread syntax to render attributes from untrusted data, event handler properties are included in the rendered HTML output. If an application spreads user-controlled or external data as element attributes, an attacker can inject malicious event handlers that execute in victims' browsers. This vulnerability is fixed in 5.51.5.","cvss":[{"source":"nvd@nist.gov","type":"Primary","version":"3.1","vector":"CVSS:3.1/AV:N/AC:L/PR:L/UI:R/S:C/C:L/I:L/A:N","metrics":{"baseScore":5.4,"exploitabilityScore":2.3,"impactScore":2.8},"vendorMetadata":{}},{"source":"security-advisories@github.com","type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:H/AT:P/PR:H/UI:N/VC:L/VI:N/VA:N/SC:H/SI:H/SA:N/E:X/CR:X/IR:X/AR:X/MAV:X/MAC:X/MAT:X/MPR:X/MUI:X/MVC:X/MVI:X/MVA:X/MSC:X/MSI:X/MSA:X/S:X/AU:X/R:X/V:X/RE:X/U:X","metrics":{"baseScore":5.1},"vendorMetadata":{}}],"epss":[{"cve":"CVE-2026-27121","epss":0.00011,"percentile":0.01267,"date":"2026-04-19"}],"cwes":[{"cve":"CVE-2026-27121","cwe":"CWE-79","source":"security-advisories@github.com","type":"Primary"}]}],"matchDetails":[{"type":"exact-direct-match","matcher":"javascript-matcher","searchedBy":{"language":"javascript","namespace":"github:language:javascript","package":{"name":"svelte","version":"4.2.18"}},"found":{"vulnerabilityID":"GHSA-f7gr-6p89-r883","versionConstraint":"<=5.51.4 (semantic)"},"fix":{"suggestedVersion":"5.51.5"}}],"artifact":{"id":"f961ef650edc323b","name":"svelte","version":"4.2.18","type":"npm","locations":[{"path":"/pnpm-lock.yaml","accessPath":"/pnpm-lock.yaml","annotations":{"evidence":"primary"}}],"language":"javascript","licenses":[],"cpes":["cpe:2.3:a:svelte:svelte:4.2.18:*:*:*:*:node.js:*:*"],"purl":"pkg:npm/svelte@4.2.18","upstreams":[]}},{"vulnerability":{"id":"GHSA-m56q-vw4c-c2cp","dataSource":"https://github.com/advisories/GHSA-m56q-vw4c-c2cp","namespace":"github:language:javascript","severity":"Medium","urls":["https://github.com/sveltejs/svelte/security/advisories/GHSA-m56q-vw4c-c2cp","https://nvd.nist.gov/vuln/detail/CVE-2026-27122"],"description":"Svelte SSR does not validate dynamic element tag names in `<svelte:element>`","cvss":[{"type":"Secondary","version":"4.0","vector":"CVSS:4.0/AV:N/AC:H/AT:P/PR:H/UI:N/VC:L/VI:N/VA:N/SC:H/SI:H/SA:N","metrics":{"baseScore":5.1},"vendorMetadata":{}}],"epss":[{"c